# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/lesefluss

# Better Auth - generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=changeme_replace_with_random_hex

# Base URL of the deployed site (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000

# Catalog service — base URL (no trailing slash) and shared admin bearer token.
# Server-only; CATALOG_ADMIN_SECRET must never reach the browser.
CATALOG_URL=http://localhost:2999
CATALOG_ADMIN_SECRET=

# Optional GlitchTip/Sentry-compatible error tracking.
# VITE_SENTRY_DSN is public and enables browser error reporting.
# SENTRY_DSN is server-only and enables SSR/API error reporting.
VITE_SENTRY_DSN=
SENTRY_DSN=

RESEND_API_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
