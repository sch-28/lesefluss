# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/lesefluss

# Better Auth - generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=changeme_replace_with_random_hex

# Base URL of the deployed site (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000

# GoatCounter analytics endpoint (no trailing slash). Leave empty to disable.
GOATCOUNTER_URL=

# Set to any non-empty value to hide all GitHub links and references site-wide.
# Use this while the repo is private.
HIDE_GITHUB=

# Admin page access - set to your account email to unlock /admin
ADMIN_EMAIL=
