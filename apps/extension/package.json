{
	"name": "@lesefluss/extension",
	"version": "1.0.0",
	"private": true,
	"description": "Lesefluss browser extension",
	"type": "module",
	"scripts": {
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox --mv3",
		"build": "wxt build",
		"build:firefox": "wxt build -b firefox --mv3",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox --mv3",
		"gen-icons": "pnpm --dir ../.. gen-icons",
		"postinstall": "wxt prepare",
		"check-types": "wxt prepare && tsc --noEmit",
		"test": "vitest run",
		"format": "biome format --write .",
		"lint": "biome lint --write .",
		"biome": "biome check --write ."
	},
	"dependencies": {
		"@fontsource-variable/geist": "5.2.8",
		"@lesefluss/core": "workspace:*",
		"@mozilla/readability": "^0.6.0",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"lucide-react": "1.8.0",
		"radix-ui": "1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"shadcn": "4.2.0",
		"tailwind-merge": "^2.6.1",
		"tw-animate-css": "1.4.0"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.2.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@wxt-dev/module-react": "^1.2.1",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vitest": "^4.1.5",
		"wxt": "^0.20.25"
	}
}
