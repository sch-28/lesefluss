# Shared Postgres instance (same DB as apps/web — catalog uses `catalog_` prefixed tables)
DATABASE_URL=postgres://user:password@localhost:5432/lesefluss

# Standard Ebooks patron credentials (required for SE OPDS feed — https://standardebooks.org/patrons)
# If unset, SE sync is skipped and only Gutenberg is indexed.
SE_EMAIL=
SE_PASSWORD=

# Shared bearer token for POST /admin/sync (called by apps/web admin page)
CATALOG_ADMIN_SECRET=

# HTTP port (default 2999 — kept off 3000 to avoid conflict with apps/web locally)
PORT=2999
