# PostgreSQL password (used by both db and web services)
POSTGRES_PASSWORD=changeme

# Better Auth - generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=changeme_replace_with_random_hex

# Base URL of the deployed site (no trailing slash)
BETTER_AUTH_URL=https://lesefluss.app

# Optional GlitchTip/Sentry-compatible error tracking.
# VITE_SENTRY_DSN is public and enables browser error reporting for the web build.
# SENTRY_DSN is server-only and enables website SSR/API error reporting.
VITE_SENTRY_DSN=
SENTRY_DSN=

# Host port (default 3000)
# PORT=3000
